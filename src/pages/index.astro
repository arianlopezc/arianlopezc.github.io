---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = [
  {
    title: 'Your AI Agent Doesn\'t Need More Guardrails. It Needs a Better Project.',
    slug: 'ai-agent-scaffolding-five-layers',
    date: '2026-02-24',
    excerpt: 'Five layers of project scaffolding that reduce AI code review to near-zero.',
  },
  {
    title: 'Your AI Agent Writes Great Code. Your Project Just Can\'t Tell It the Rules.',
    slug: 'stop-reviewing-ai-agent-code',
    date: '2026-02-22',
    excerpt: 'You need to stop reviewing your agent\'s generated code for style violations.',
  },
  {
    title: 'I Built an MCP Tool That Was Confidently Wrong',
    slug: 'mcp-tool-design-for-ai-agents',
    date: '2026-02-22',
    excerpt: 'I shipped a tool that made AI agents worse at their job. Here\'s what I learned about designing for AI agents.',
  },
  {
    title: 'I Built a CLI That Generates Production-Ready Java Projects in Seconds',
    slug: 'trabuco-cli-generates-java-projects',
    date: '2026-02-14',
    excerpt: 'Why AI-generated projects fail teams, and what consistency actually looks like.',
  },
  {
    title: 'Rate Limiting a Tenant\'s Import Data with a Leaky Bucket Strategy',
    slug: 'rate-limiting-leaky-bucket-strategy',
    date: '2023-05-03',
    excerpt: 'Repurposing a network algorithm to protect a multi-tenant import pipeline.',
  },
  {
    title: 'Accelerating CRUD Async Operations with Redis and Queues',
    slug: 'accelerating-crud-async-redis-queues',
    date: '2023-01-15',
    excerpt: 'Write-back caching with Redis and job queues as a database accelerator.',
  },
  {
    title: 'Lessons Learned Using Spring Data Redis',
    slug: 'lessons-learned-spring-data-redis',
    date: '2021-10-05',
    excerpt: 'Debugging a hidden memory leak caused by Spring Data Redis internals.',
  },
];
---

<BaseLayout title="Arian Lopez">
  <section class="hero">
    <h1>Hi, I'm Arian</h1>
    <p class="intro">
      I'm a software engineer interested in distributed systems, platform infrastructure, and
      what happens when you give AI tools real context about your codebase. I write about
      problems I've run into at work and the solutions that stuck.
    </p>
  </section>

  <hr />

  <section class="section">
    <p class="section-title">Writing</p>
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a href={`/blog/${post.slug}`}>
            <span class="post-title">{post.title}</span>
            <span class="post-date">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            <p class="post-excerpt">{post.excerpt}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2rem 0 0.5rem;
  }

  .hero h1 {
    font-size: 2.2rem;
    margin-bottom: 0.8rem;
  }

  .intro {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 1.8rem;
    }
  }
</style>
