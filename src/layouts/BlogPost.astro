---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  description?: string;
  readingTime?: string;
}

const { title, date, description, readingTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Arian Lopez`} description={description}>
  <article class="blog-post">
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={date}>{formattedDate}</time>
        {readingTime && <span class="reading-time">{readingTime}</span>}
      </div>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
  }

  .post-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }

  .post-meta {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    display: flex;
    gap: 1rem;
  }

  .reading-time::before {
    content: '\00b7';
    margin-right: 0.5rem;
  }

  .post-content {
    font-size: 1rem;
  }

  .post-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.8rem;
  }

  .post-content :global(h3) {
    margin-top: 1.8rem;
    margin-bottom: 0.6rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.2rem;
  }
</style>
